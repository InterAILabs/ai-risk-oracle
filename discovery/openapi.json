{
  "openapi": "3.1.0",
  "info": {
    "title": "InterAI Risk Oracle Public API",
    "version": "0.0.0-public-beta",
    "description": "Public hosted API contracts for InterAI Risk Oracle, an autonomous execution gateway for pre-execution verification of autonomous agents."
  },
  "servers": [
    {
      "url": "https://ai-risk-oracle.fly.dev"
    }
  ],
  "paths": {
    "/verify": {
      "post": {
        "summary": "Verify an autonomous action before execution",
        "description": "Receives the autonomous_execution request contract and returns a risk score, policy result, recommended action, machine-readable signals, and trust receipt metadata.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "../schemas/verify-request.schema.json"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Verification decision",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../schemas/verify-response.schema.json"
                }
              }
            }
          }
        }
      }
    },
    "/.well-known/autonomous-adoption.json": {
      "get": {
        "summary": "Get autonomous adoption contract",
        "description": "Machine-readable guidance for agents and builders deciding when and how to use InterAI before execution.",
        "responses": {
          "200": {
            "description": "Autonomous adoption contract"
          }
        }
      }
    },
    "/pricing": {
      "get": {
        "summary": "Get self-serve pricing metadata",
        "responses": {
          "200": {
            "description": "Pricing, x402, trial, and onboarding metadata"
          }
        }
      }
    },
    "/onboard": {
      "post": {
        "summary": "Create a self-serve API key account",
        "responses": {
          "200": {
            "description": "Account and API key created"
          }
        }
      }
    },
    "/demo": {
      "get": {
        "summary": "Run controlled demo walkthrough",
        "description": "Human-facing demo for creating a limited demo_trial key, running a safe read-only verification, and viewing a public trust receipt.",
        "responses": {
          "200": {
            "description": "Controlled demo page"
          }
        }
      }
    },
    "/robots.txt": {
      "get": {
        "summary": "Get crawler policy",
        "responses": {
          "200": {
            "description": "Crawler policy with sitemap location"
          }
        }
      }
    },
    "/sitemap.xml": {
      "get": {
        "summary": "Get XML sitemap",
        "responses": {
          "200": {
            "description": "Public discovery sitemap"
          }
        }
      }
    },
    "/llms.txt": {
      "get": {
        "summary": "Get LLM discovery summary",
        "responses": {
          "200": {
            "description": "LLM-readable service summary"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  }
}
