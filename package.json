{
  "name": "ai-risk-oracle",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.sdk.json",
    "test": "npm run build && node tests/run.mjs",
    "start": "node dist/server.js",
    "smoke": "node ./scripts/smoke-test.js",
    "smoke:billing": "node ./scripts/smoke-billing-regression.js",
    "smoke:topup-confirm": "node ./scripts/smoke-topup-confirm.js",
    "smoke:idempotency": "node ./scripts/smoke-idempotency.js",
    "smoke:trust-signing": "node ./scripts/smoke-trust-signing.js",
    "smoke:sdk": "node ./scripts/smoke-sdk.js",
    "example": "node ./examples/test.js",
    "example:basic": "tsx ./examples/basic-agent.mjs",
    "example:basic:prod": "tsx ./examples/basic-agent-production.mjs"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "dotenv": "^17.4.1",
    "fastify": "^4.25.0",
    "viem": "^2.47.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.1",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  }
}
