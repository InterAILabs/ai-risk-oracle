{
  "name": "ai-risk-oracle",
  "version": "0.0.1",
  "description": "AI-to-AI risk, trust receipt, and prepaid verification primitive for autonomous agents.",
  "type": "module",
  "main": "./dist/sdk/interai-risk-oracle.js",
  "types": "./dist/sdk/interai-risk-oracle.d.ts",
  "exports": {
    ".": {
      "types": "./dist/sdk/interai-risk-oracle.d.ts",
      "import": "./dist/sdk/interai-risk-oracle.js"
    },
    "./sdk": {
      "types": "./dist/sdk/interai-risk-oracle.d.ts",
      "import": "./dist/sdk/interai-risk-oracle.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "docs"
  ],
  "keywords": [
    "ai-agents",
    "a2a",
    "mcp",
    "risk-oracle",
    "trust-receipts",
    "base-usdc"
  ],
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.sdk.json",
    "typecheck:examples": "npm run build && tsc -p tsconfig.examples.json",
    "test": "npm run build && node tests/run.mjs",
    "contracts": "npm run build && node ./scripts/check-contracts.js",
    "benchmark": "npm run build && node ./benchmarks/run-benchmark.mjs",
    "secrets:check": "node ./scripts/check-secrets.js",
    "python:sdk": "node ./scripts/check-python-sdk.js",
    "package:check": "npm run build && node ./scripts/check-package.js",
    "deploy:check": "node ./scripts/check-production-config.js",
    "start": "node dist/server.js",
    "smoke": "node ./scripts/smoke-test.js",
    "smoke:billing": "node ./scripts/smoke-billing-regression.js",
    "smoke:topup-confirm": "node ./scripts/smoke-topup-confirm.js",
    "smoke:idempotency": "node ./scripts/smoke-idempotency.js",
    "smoke:trust-signing": "node ./scripts/smoke-trust-signing.js",
    "smoke:sdk": "npm run build && node ./scripts/smoke-sdk.js",
    "smoke:online": "node ./tools/smoke-online.mjs",
    "example": "node ./examples/test.js",
    "example:basic": "tsx ./examples/basic-agent.mjs",
    "example:basic:prod": "tsx ./examples/basic-agent-production.mjs",
    "example:x402": "tsx ./examples/x402-client.ts",
    "example:semantic-judge": "tsx ./examples/semantic-judge-trial.ts",
    "example:pre-payment": "tsx ./examples/pre-payment-verification.ts",
    "example:pre-tool": "tsx ./examples/pre-tool-execution-check.ts",
    "example:agent-before-payment": "tsx ./examples/agent-before-payment.mjs",
    "example:agent-before-tool": "tsx ./examples/agent-before-tool-execution.mjs",
    "example:mcp-agent": "tsx ./examples/mcp-agent-verify.ts",
    "example:a2a-agent": "tsx ./examples/a2a-agent-verify.ts"
  },
  "dependencies": {
    "@x402/core": "^2.12.0",
    "better-sqlite3": "^11.10.0",
    "dotenv": "^17.4.1",
    "fastify": "^5.8.5",
    "viem": "^2.50.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.1",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  }
}
