{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/InterAILabs/ai-risk-oracle/main/schemas/verify-response.schema.json",
  "title": "InterAI Autonomous Execution Verify Response",
  "type": "object",
  "required": [
    "decision_id",
    "request_contract",
    "score",
    "risk_level",
    "signals",
    "recommended_action",
    "policy_result",
    "policy_violations",
    "trust_receipt_id",
    "trust_receipt"
  ],
  "properties": {
    "decision_id": {
      "type": "string"
    },
    "request_contract": {
      "type": "string",
      "const": "autonomous_execution"
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Risk score. Higher means higher execution risk."
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "signals": {
      "type": "object",
      "properties": {
        "semantic_relevance": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "contradiction_risk": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "unsupported_specificity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "numeric_consistency": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "overconfidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "has_external_side_effect": {
          "type": "boolean"
        },
        "is_irreversible": {
          "type": "boolean"
        },
        "involves_money": {
          "type": "boolean"
        },
        "amount_usd": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "requires_user_confirmation": {
          "type": "boolean"
        },
        "has_counterparty": {
          "type": "boolean"
        },
        "environment": {
          "type": "string"
        },
        "action_type": {
          "type": [
            "string",
            "null"
          ]
        },
        "autonomous_execution_detected": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "recommended_action": {
      "type": "string",
      "enum": [
        "allow",
        "review_required",
        "block"
      ]
    },
    "policy_result": {
      "type": "string",
      "enum": [
        "allow",
        "review_required",
        "block"
      ]
    },
    "policy_violations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "code",
          "message",
          "severity"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "allow",
              "review_required",
              "block"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "trust_receipt_id": {
      "type": "string"
    },
    "trust_receipt": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
