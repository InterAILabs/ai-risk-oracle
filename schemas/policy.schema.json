{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/InterAILabs/ai-risk-oracle/main/schemas/policy.schema.json",
  "title": "InterAI Autonomous Execution Policy",
  "type": "object",
  "properties": {
    "max_risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "require_trust_receipt": { "type": "boolean" },
    "amount_usd_limit": { "type": "number", "minimum": 0 },
    "blocked_action_types": {
      "type": "array",
      "items": { "type": "string" }
    },
    "allowed_action_types": {
      "type": "array",
      "items": { "type": "string" }
    },
    "require_human_review_above": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "require_user_confirmation_for_irreversible": { "type": "boolean" }
  },
  "additionalProperties": true
}
